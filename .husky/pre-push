#!/bin/sh
# Runs before every push — full test suite + type check + exercise sync check
echo "🔍 Running pre-push checks..."
npx tsc --noEmit && npm test

# ── Exercise sync check ───────────────────────────────────────────────────
# Blocks push if any lesson ID in modules.ts is missing from exercisePaths.ts
node -e "
const fs = require('fs');

const modules = fs.readFileSync('src/data/modules.ts', 'utf8');
const paths   = fs.readFileSync('src/data/exercisePaths.ts', 'utf8');

// Extract all lesson IDs defined in modules.ts
const lessonIds = [...modules.matchAll(/id:\s*'(lesson-\d+-\d+)'/g)].map(m => m[1]);

// Extract all lesson IDs mapped in exercisePaths.ts
const mapped = new Set([...paths.matchAll(/'(lesson-\d+-\d+)':/g)].map(m => m[1]));

const missing = lessonIds.filter(id => !mapped.has(id));

if (missing.length > 0) {
  console.error('');
  console.error('❌ Exercise sync check failed — missing entries in exercisePaths.ts:');
  missing.forEach(id => console.error('   ' + id));
  console.error('');
  console.error('Add each ID to src/data/exercisePaths.ts and create the');
  console.error('corresponding folder in the claude-mastery-exercises repo before pushing.');
  console.error('');
  process.exit(1);
}
" || exit 1

echo "✅ All checks passed"
